NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=
CODEX_PETS_DATA_SOURCE=

# Set CODEX_PETS_DATA_SOURCE=mock to run the app with built-in local sample
# pets and generated assets without YDB.

# Internal auth
# app-session   -> built-in email+password accounts stored in YDB
# single-user   -> local dev fallback with one synthetic admin account
# proxy-basic   -> legacy reverse-proxy fallback, not primary UX
AUTH_MODE=app-session
AUTH_SINGLE_USER_ID=local-admin
AUTH_SINGLE_USER_EMAIL=
AUTH_SINGLE_USER_NAME=
SESSION_COOKIE_SECRET=
PASSWORD_PEPPER=
INITIAL_ADMIN_EMAILS=admin@example.com

# local-ydb / YDB native gRPC
# Example:
# YDB_PETS_ENDPOINT=grpc://ydb-host:2137
# YDB_PETS_DATABASE=/local/your-tenant
# If the endpoint uses a Docker hostname such as `ydb-local`, the app container
# must join the same Docker network as YDB (for example `--network ydb-net`).
# For host-to-Docker local-ydb development, use:
# YDB_ANONYMOUS_CREDENTIALS=1
# YDB_ENDPOINT=grpc://127.0.0.1:2136
# YDB_PETS_ENDPOINT=grpc://127.0.0.1:2136
# YDB_PETS_DATABASE=/local
YDB_ANONYMOUS_CREDENTIALS=
YDB_ENDPOINT=
YDB_PETS_ENDPOINT=
YDB_PETS_DATABASE=
YDB_STATIC_CREDENTIALS_USER=
YDB_STATIC_CREDENTIALS_PASSWORD=
YDB_STATIC_CREDENTIALS_PASSWORD_FILE=
YDB_STATIC_CREDENTIALS_AUTH_ENDPOINT=
