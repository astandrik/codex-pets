CREATE TABLE codex_pets (
  slug Utf8 NOT NULL,
  id Utf8 NOT NULL,
  display_name Utf8 NOT NULL,
  description Utf8 NOT NULL,
  spritesheet_url Utf8 NOT NULL,
  pet_json_url Utf8 NOT NULL,
  zip_url Utf8 NOT NULL,
  spritesheet_ext Utf8 NOT NULL,
  kind Utf8 NOT NULL,
  tags_json Utf8 NOT NULL,
  status Utf8 NOT NULL,
  owner_id Utf8 NOT NULL,
  owner_email Utf8 NOT NULL,
  owner_name Utf8 NOT NULL,
  contact_email Utf8 NOT NULL,
  rejection_reason Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  updated_at Utf8 NOT NULL,
  approved_at Utf8 NOT NULL,
  rejected_at Utf8 NOT NULL,
  PRIMARY KEY (slug)
);

CREATE TABLE codex_pet_assets (
  asset_id Utf8 NOT NULL,
  pet_json_bytes String NOT NULL,
  spritesheet_bytes String NOT NULL,
  zip_bytes String NOT NULL,
  spritesheet_ext Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  PRIMARY KEY (asset_id)
);

CREATE TABLE codex_users (
  user_id Utf8 NOT NULL,
  email Utf8 NOT NULL,
  email_lower Utf8 NOT NULL,
  password_hash Utf8 NOT NULL,
  display_name Utf8 NOT NULL,
  role Utf8 NOT NULL,
  status Utf8 NOT NULL,
  email_verified_at Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  updated_at Utf8 NOT NULL,
  PRIMARY KEY (user_id)
);

CREATE TABLE codex_sessions (
  session_id Utf8 NOT NULL,
  user_id Utf8 NOT NULL,
  expires_at Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  PRIMARY KEY (session_id)
);

CREATE TABLE codex_email_verification_tokens (
  token_hash Utf8 NOT NULL,
  user_id Utf8 NOT NULL,
  email_lower Utf8 NOT NULL,
  expires_at Utf8 NOT NULL,
  consumed_at Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  PRIMARY KEY (token_hash)
);

CREATE TABLE codex_password_reset_tokens (
  token_hash Utf8 NOT NULL,
  user_id Utf8 NOT NULL,
  email_lower Utf8 NOT NULL,
  expires_at Utf8 NOT NULL,
  consumed_at Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  PRIMARY KEY (token_hash)
);

CREATE TABLE codex_pet_upload_sessions (
  id Utf8 NOT NULL,
  owner_id Utf8 NOT NULL,
  pet_id_hint Utf8 NOT NULL,
  slug_hint Utf8 NOT NULL,
  zip_url Utf8 NOT NULL,
  pet_json_url Utf8 NOT NULL,
  spritesheet_url Utf8 NOT NULL,
  spritesheet_ext Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  expires_at Utf8 NOT NULL,
  consumed_at Utf8 NOT NULL,
  PRIMARY KEY (id)
);

CREATE TABLE codex_pet_reviews (
  id Utf8 NOT NULL,
  pet_id Utf8 NOT NULL,
  reviewer_id Utf8 NOT NULL,
  decision Utf8 NOT NULL,
  reason Utf8 NOT NULL,
  created_at Utf8 NOT NULL,
  PRIMARY KEY (id)
);

CREATE TABLE codex_pet_metrics (
  pet_slug Utf8 NOT NULL,
  download_count Uint32 NOT NULL,
  install_count Uint32 NOT NULL,
  like_count Uint32 NOT NULL,
  updated_at Utf8 NOT NULL,
  PRIMARY KEY (pet_slug)
);

CREATE TABLE codex_schema_migrations (
  id Utf8 NOT NULL,
  applied_at Utf8 NOT NULL,
  PRIMARY KEY (id)
);
