NODE_ENV=production
PORT=3000

# Public app URL and optional path prefix
# For a dedicated subdomain like https://pets.example.com, set:
# NEXT_PUBLIC_APP_URL=https://pets.example.com
# NEXT_PUBLIC_BASE_PATH=
# For a subpath deployment like https://example.com/codex-pets, set:
# NEXT_PUBLIC_APP_URL=https://example.com/codex-pets
# NEXT_PUBLIC_BASE_PATH=/codex-pets
NEXT_PUBLIC_APP_URL=https://pets.example.com
NEXT_PUBLIC_BASE_PATH=

# App-owned auth
AUTH_MODE=app-session
SESSION_COOKIE_SECRET=
PASSWORD_PEPPER=
INITIAL_ADMIN_EMAILS=admin@example.com

# YDB connection
# If any YDB endpoint uses a Docker hostname such as `ydb-local`, run the app
# container on the same Docker network (for example `--network ydb-net`).
YDB_PETS_ENDPOINT=grpc://ydb-host:2137
YDB_PETS_DATABASE=/local/your-tenant
YDB_STATIC_CREDENTIALS_USER=appuser
YDB_STATIC_CREDENTIALS_PASSWORD=
YDB_STATIC_CREDENTIALS_PASSWORD_FILE=/run/secrets/app.password
YDB_STATIC_CREDENTIALS_AUTH_ENDPOINT=grpc://ydb-host:2136
